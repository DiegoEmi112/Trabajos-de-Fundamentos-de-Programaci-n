Proceso dosNumeros
	// Nombre del alumno: Diego Emiliano Quińones Barraza 
    // Numero de control: 25041722
	Definir n1, n2 Como Entero;
	Escribir "Dame el primer número: ";
	Leer n1;
	Escribir "Dame el segundo número: ";
	Leer n2;
	Escribir n1, "+", n2, "=", n1 + n2;
	Escribir n1, "-", n2, "=", n1 - n2;
	Escribir n1, "*", n2, "=", n1 * n2;
	Escribir n1, "/", n2, "=", n1 / n2;
FinProceso