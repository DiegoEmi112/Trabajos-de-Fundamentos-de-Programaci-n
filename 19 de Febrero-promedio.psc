Algoritmo promedio
	// Nombre del alumno: Diego Emiliano Quińones Barraza 
    // Numero de control: 25041722
    Definir n1, n2, n3, prom Como Real;
    
    Escribir "Dime el número 1: ";
    Leer n1;
    
    Escribir "Dime el número 2: ";
    Leer n2;
    
    Escribir "Dime el número 3: ";
    Leer n3;
    
    prom <- (n1 + n2 + n3) / 3;
    
    Escribir "El promedio de: ", n1, ", ", n2, " y ", n3, " es: ", prom;
FinAlgoritmo